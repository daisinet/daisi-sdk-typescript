{
  "name": "@daisi/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the DAISI network — gRPC clients for auth, inference, drives, sessions, and more",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.mjs",
      "require": "./dist/web.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "npx buf generate",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "long": "^5.2.3",
    "nice-grpc": "^2.1.10",
    "nice-grpc-common": "^2.0.2",
    "nice-grpc-web": "^3.3.9",
    "protobufjs": "^7.4.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.65.0",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "grpc-tools": "^1.12.4",
    "prettier": "^3.4.0",
    "ts-proto": "^2.6.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/daisinet/daisi-sdk-typescript.git"
  },
  "keywords": [
    "daisi",
    "daisinet",
    "grpc",
    "sdk",
    "inference",
    "ai"
  ]
}
